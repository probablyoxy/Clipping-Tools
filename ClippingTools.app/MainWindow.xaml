<Window x:Class="ClippingTools.app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClippingTools.app"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800" Background="#1e1e1e"
        Closing="Window_Closing">
    <Grid Background="#36393f">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#2f3136">
            <TextBlock Text="Clipping Tools" Foreground="White" FontSize="20" FontWeight="Bold" Margin="20,20,0,30"/>

            <Button x:Name="NavHomeBtn" Content="Home" Height="40" Margin="10,0,10,10" Background="#4f545c" Foreground="White" BorderThickness="0" Click="NavHomeBtn_Click"/>
            <Button x:Name="NavDiscordBtn" Content="Discord" Height="40" Margin="10,0,10,10" Background="#2f3136" Foreground="White" BorderThickness="0" Click="NavDiscordBtn_Click"/>
            <Button x:Name="NavSettingsBtn" Content="Settings" Height="40" Margin="10,0,10,10" Background="#2f3136" Foreground="White" BorderThickness="0" Click="NavSettingsBtn_Click"/>
            <Button x:Name="NavExtrasBtn" Content="Extras" Height="40" Margin="10,0,10,10" Background="#2f3136" Foreground="White" BorderThickness="0" Click="NavExtrasBtn_Click"/>
            <Button x:Name="NavUpdateBtn" Content="Update" Height="40" Margin="10,0,10,10" Background="#2f3136" Foreground="White" BorderThickness="0" Click="NavUpdateBtn_Click"/>
            <Button x:Name="NavLogsBtn" Content="Logs" Height="40" Margin="10,0,10,10" Background="#2f3136" Foreground="White" BorderThickness="0" Click="NavLogsBtn_Click"/>
            <Button x:Name="NavHelpBtn" Content="Help" Height="40" Margin="10,0,10,10" Background="#2f3136" Foreground="White" BorderThickness="0" Click="NavHelpBtn_Click"/>
        </StackPanel>

        <TabControl x:Name="MainContent" Grid.Column="1" Background="Transparent" BorderThickness="0" Margin="20">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.ItemContainerStyle>

            <TabItem>
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Home" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                        <CheckBox x:Name="SendClipsCheck" Content="Send clipping actions to others" Foreground="White" IsChecked="True" Margin="0,0,0,10" Click="Setting_Changed"/>
                        <CheckBox x:Name="ReceiveClipsCheck" Content="Receive clipping actions from others" Foreground="White" IsChecked="True" Margin="0,0,0,30" Click="Setting_Changed"/>
                        <Button x:Name="ConnectButton" Content="Activate Syncing" Height="40" Width="200" HorizontalAlignment="Left" Background="#5865F2" Foreground="White" FontWeight="Bold" Click="ConnectButton_Click"/>
                        <CheckBox x:Name="AutoSyncCheck" Content="Sync Automatically on startup" Foreground="White" Margin="0,15,0,10" Click="Setting_Changed"/>
                        <CheckBox x:Name="StartWithWindowsCheck" Content="Start with Windows" Foreground="White" Margin="0,0,0,10" Click="StartWithWindowsCheck_Click"/>
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Cursor="Hand" MouseLeftButtonDown="ServerStatus_Click" ToolTip="Click to force reconnect">
                            <Ellipse x:Name="ServerStatusDot" Width="10" Height="10" Fill="IndianRed" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ServerStatusText" Text="Disconnected" Foreground="#b9bbbe" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="CurrentVcText" Text="Current VC: Unknown" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Right" Margin="0,15,0,10" Visibility="Collapsed"/>
                        <StackPanel x:Name="VcUsersPanel" HorizontalAlignment="Right" Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem>
                <StackPanel>
                    <TextBlock Text="Discord Integration" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                    <TextBlock Text="Your Discord ID:" Foreground="#b9bbbe" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DiscordIdInput" Grid.Column="0" Height="30" Margin="0,0,10,0" Background="#202225" Foreground="#b9bbbe" BorderBrush="#202225" IsReadOnly="True" TextChanged="Setting_TextChanged"/>
                        <Button x:Name="DiscordSignInBtn" Grid.Column="1" Content="Sign In w/ Discord" Background="#5865F2" Foreground="White" BorderThickness="0" Click="DiscordSignInBtn_Click"/>
                    </Grid>
                    <TextBlock Text="Approved Users List (Mutual sync required):" Foreground="White" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Text="Paste User IDs here (one per line, space, or comma). Click an ID to remove it." Foreground="#b9bbbe" FontSize="11" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="55"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="NewUserIdInput" Grid.Column="0" Height="25" Background="#202225" Foreground="White" BorderBrush="#202225" Margin="0,0,5,0" KeyDown="NewUserIdInput_KeyDown"/>
                            <Button Grid.Column="1" Content="Select Users" Background="#4f545c" Foreground="White" BorderThickness="0" Margin="0,0,5,0" Click="OpenSelectUsersBtn_Click"/>
                            <Button Grid.Column="2" Content="Add" Background="#4f545c" Foreground="White" BorderThickness="0" Click="AddUserBtn_Click"/>
                        </Grid>
                        <ListBox x:Name="UserListBox" Grid.Row="1" Background="#202225" BorderBrush="#202225" Foreground="White" ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.HorizontalScrollBarVisibility="Auto" Padding="0,0,0,5">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Button Background="#4f545c" Foreground="White" BorderThickness="0" Cursor="Hand" Click="RemoveUserBtn_Click" Padding="15,5" Margin="0,2,5,2" ToolTip="{Binding Id}">
                                        <TextBlock Text="{Binding DisplayName}"/>
                                    </Button>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>
                    <TextBlock Text="Voice Channel Sync Rules:" Foreground="White" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel>
                        <RadioButton x:Name="RadioAnyVC" GroupName="VCRules" Content="Sync in ANY Voice Channel with Approved Users" Foreground="#b9bbbe" IsChecked="True" Margin="0,0,0,10" Checked="RadioVCRules_Changed"/>
                        <RadioButton x:Name="RadioSpecificVC" GroupName="VCRules" Content="Only sync when in these specific Channel IDs:" Foreground="#b9bbbe" Margin="0,0,0,5" Checked="RadioVCRules_Changed"/>
                        <Grid x:Name="ChannelListContainer" Margin="20,0,0,0" IsEnabled="False" Opacity="0.5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="55"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="NewChannelIdInput" Grid.Column="0" Height="25" Background="#202225" Foreground="White" BorderBrush="#202225" Margin="0,0,5,0" KeyDown="NewChannelIdInput_KeyDown"/>
                                <Button Grid.Column="1" Content="Add" Background="#4f545c" Foreground="White" BorderThickness="0" Click="AddChannelBtn_Click"/>
                            </Grid>
                            <ListBox x:Name="ChannelListBox" Grid.Row="1" Background="#202225" BorderBrush="#202225" Foreground="White" ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.HorizontalScrollBarVisibility="Auto" Padding="0,0,0,5">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Button Background="#4f545c" Foreground="White" BorderThickness="0" Cursor="Hand" Click="RemoveChannelBtn_Click" Padding="15,5" Margin="0,2,5,2" ToolTip="{Binding Id}">
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </Button>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem>
                <StackPanel>
                    <Grid Margin="0,0,0,20">
                        <TextBlock Text="Settings" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="ImportSettingsBtn" Content="Import" Background="#4f545c" Foreground="White" BorderThickness="0" Width="60" Height="25" Margin="0,0,10,0" Click="ImportSettingsBtn_Click"/>
                            <Button x:Name="ExportSettingsBtn" Content="Export" Background="#4f545c" Foreground="White" BorderThickness="0" Width="60" Height="25" Click="ExportSettingsBtn_Click"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="EnableSoundCheck" Grid.Column="0" Content="Play sound effect when a clip is taken" Foreground="White" IsChecked="True" VerticalAlignment="Center" Click="Setting_Changed"/>
                        <Button Grid.Column="1" Content="Test Sound" Background="#4f545c" Foreground="White" BorderThickness="0" Height="25" Click="TestSoundBtn_Click"/>
                    </Grid>
                    <Grid Margin="20,0,0,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <RadioButton x:Name="RadioSystemSound" Grid.Column="0" Content="Use System Sound:" Foreground="#b9bbbe" IsChecked="True" GroupName="SoundType" Checked="Setting_Changed" Unchecked="Setting_Changed" VerticalAlignment="Center"/>
                            <ComboBox x:Name="SystemSoundCombo" Grid.Column="1" SelectionChanged="SystemSoundCombo_SelectionChanged">
                                <ComboBoxItem Content="Exclamation" IsSelected="True"/>
                                <ComboBoxItem Content="Asterisk"/>
                                <ComboBoxItem Content="Beep"/>
                                <ComboBoxItem Content="Hand"/>
                                <ComboBoxItem Content="Question"/>
                            </ComboBox>
                        </Grid>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <RadioButton x:Name="RadioCustomSound" Grid.Column="0" Content="Use Custom Audio File:" Foreground="#b9bbbe" GroupName="SoundType" Checked="Setting_Changed" Unchecked="Setting_Changed" VerticalAlignment="Center"/>
                            <TextBox x:Name="CustomSoundPathInput" Grid.Column="1" IsReadOnly="True" Height="25" Background="#202225" Foreground="#b9bbbe" BorderBrush="#202225" Margin="0,0,5,0" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="2" Content="Browse" Background="#4f545c" Foreground="White" BorderThickness="0" Click="BrowseSoundBtn_Click"/>
                        </Grid>
                    </Grid>
                    <Rectangle Height="1" Fill="#202225" Margin="0,0,0,20"/>
                    <TextBlock Text="Trigger Keybind (Keybind used to create a synced clip):" Foreground="#b9bbbe" Margin="0,0,0,5"/>
                    <TextBox x:Name="TriggerKeyInput" Text="Ctrl+Alt+F10" IsReadOnly="True" PreviewKeyDown="HotkeyInput_PreviewKeyDown" PreviewKeyUp="HotkeyInput_PreviewKeyUp" Height="30" Margin="0,0,0,15" Background="#202225" Foreground="White" BorderBrush="#202225"/>
                    <TextBlock Text="Software Clip Keybind (Click each box and press ONE key at a time. Press Esc to clear):" Foreground="#b9bbbe" Margin="0,0,0,5"/>
                    <WrapPanel x:Name="ClipKeyPanel" Margin="0,0,0,20" Orientation="Horizontal"/>

                    <Rectangle Height="1" Fill="#202225" Margin="0,10,0,20"/>
                    <Button x:Name="ResetUuidBtn" Content="Reset UUID" Background="IndianRed" Foreground="White" FontWeight="Bold" BorderThickness="0" Width="120" Height="30" HorizontalAlignment="Left" Click="ResetUuidBtn_Click"/>
                </StackPanel>
            </TabItem>

            <TabItem>
                <StackPanel>
                    <TextBlock Text="Extras" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                    <CheckBox x:Name="AutoRestartObsCheck" Content="Automatically Restart OBS Replay on Failure" Foreground="White" FontSize="14" Margin="0,0,0,10" Click="AutoRestartObsCheck_Click"/>
                    <StackPanel x:Name="ObsIntervalPanel" Visibility="Collapsed" Margin="20,0,0,10">
                        <TextBlock Text="OBS Checking Interval (Seconds)" Foreground="#b9bbbe" Margin="0,0,0,5"/>
                        <TextBox x:Name="ObsIntervalInput" Text="5" Width="50" Height="25" HorizontalAlignment="Left" Background="#202225" Foreground="White" BorderBrush="#202225" VerticalContentAlignment="Center" TextChanged="Setting_TextChanged" PreviewTextInput="NumberValidationTextBox"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>
            
            <TabItem>
                <StackPanel>
                    <TextBlock Text="Updates" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Current Version: " Foreground="#b9bbbe" FontSize="16"/>
                        <TextBlock x:Name="CurrentVersionText" Text="v1.0.0" Foreground="White" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="Latest Version: " Foreground="#b9bbbe" FontSize="16"/>
                        <TextBlock x:Name="LatestVersionText" Text="..." Foreground="White" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBlock x:Name="UpdateStatusText" Text="Checking for updates..." Foreground="#b9bbbe" FontSize="14" Margin="0,0,0,20"/>
                    <Button x:Name="PerformUpdateBtn" Content="Download and Update" Height="40" Width="200" HorizontalAlignment="Left" Background="#43b581" Foreground="White" FontWeight="Bold" Visibility="Collapsed" Click="PerformUpdateBtn_Click"/>
                    <ProgressBar x:Name="UpdateProgressBar" Height="10" Width="400" HorizontalAlignment="Left" Margin="0,10,0,0" Visibility="Collapsed" Maximum="100"/>

                    <TextBlock x:Name="ReleaseNotesTitle" Text="Release Notes:" Foreground="White" FontWeight="Bold" Margin="0,20,0,5" Visibility="Collapsed"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Height="150" Margin="0,0,0,10">
                        <TextBlock x:Name="ReleaseNotesText" Text="" Foreground="#b9bbbe" TextWrapping="Wrap" Visibility="Collapsed"/>
                    </ScrollViewer>
                </StackPanel>
            </TabItem>

            <TabItem>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Action Logs" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                        <CheckBox x:Name="EnableLoggingCheck" Content="Enable Action Logging" Foreground="White" IsChecked="True" Margin="0,0,0,10" Click="EnableLoggingCheck_Click"/>
                        <StackPanel x:Name="LogLinesPanel" Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Max lines to keep:" Foreground="#b9bbbe" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="MaxLogLinesInput" Text="1000" Width="60" Height="25" Background="#202225" Foreground="White" BorderBrush="#202225" VerticalContentAlignment="Center" TextChanged="Setting_TextChanged" PreviewTextInput="NumberValidationTextBox"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBox x:Name="LogOutputText" Grid.Row="1" Background="#202225" Foreground="#b9bbbe" BorderBrush="#202225" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" FontFamily="Consolas" Padding="5"/>
                </Grid>
            </TabItem>

            <TabItem>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Clipping Tools" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Foreground="#b9bbbe" TextWrapping="Wrap" Margin="0,0,0,15" FontSize="14">
                            <Run FontWeight="Bold" Foreground="White" Text="Clipping Tools"/>
                            <Run Text=" is a lightweight app that lets you sync your game capture software with all of your friends. When one person clips, everyone will."/>
                        </TextBlock>
                        <TextBlock Foreground="#b9bbbe" TextWrapping="Wrap" Margin="0,0,0,25" FontSize="14">
                            <Run Text="By linking with my Discord bot, "/>
                            <Hyperlink NavigateUri="https://oxy.pizza/polandbot" RequestNavigate="Hyperlink_RequestNavigate" TextDecorations="None">
                                <Run FontWeight="Bold" Foreground="#5865F2" Text="poland bot#2120"/>
                            </Hyperlink>
                            <Run Text=", the app watches your active voice channels to see who you are talking with. When you hit your clip button and send the signal, it instantly distributes it to everyone connected in your VC, triggering their software to record at the exact same time. Now you can capture everyone's perspective of the same moment, no matter what!"/>
                        </TextBlock>

                        <TextBlock Text="Getting Started" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Foreground="#b9bbbe" TextWrapping="Wrap" Margin="0,0,0,20" FontSize="14">
                            <Run Text="Follow this basic setup to get connected:"/>
                        </TextBlock>

                        <TextBlock Text="1. Authenticate" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Foreground="#b9bbbe" TextWrapping="Wrap" Margin="15,0,0,20" FontSize="14">
                            <Run Text="• Go to the "/>
                            <Run FontWeight="Bold" Foreground="White" Text="Discord"/>
                            <Run Text=" tab and press "/>
                            <Run FontWeight="Bold" Foreground="White" Text="Sign In w/ Discord"/>
                            <Run Text="."/>
                            <LineBreak/>
                            <Run Text="• Follow the steps in the new browser tab that opens."/>
                            <LineBreak/>
                            <Run Text="• When you first connect to the network, the bot will DM you to verify your Discord account and link it to the backend. Make sure it can message you or you will not be able to verify your account. "/>
                            <Run FontStyle="Italic" Text="(This is a strict security feature to prevent people from pretending to be you and sending false clip commands)."/>
                        </TextBlock>

                        <TextBlock Text="2. Configure Keybinds" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Foreground="#b9bbbe" TextWrapping="Wrap" Margin="15,0,0,20" FontSize="14">
                            <Run Text="• Go to the "/>
                            <Run FontWeight="Bold" Foreground="White" Text="Settings"/>
                            <Run Text=" tab and change the "/>
                            <Run FontWeight="Bold" Foreground="White" Text="Trigger Keybind"/>
                            <Run Text=" to something you like. This is the key used to make a shared clip with everyone connected. "/>
                            <Run FontStyle="Italic" Text="Note: This MUST be different than your normal clipping keys."/>
                            <LineBreak/>
                            <Run Text="• Change your "/>
                            <Run FontWeight="Bold" Foreground="White" Text="Software Clip Keybind"/>
                            <Run Text=" to the actual keybind used for your clipping software (the buttons you usually press to make a clip in OBS, Medal, Shadowplay, etc.)."/>
                        </TextBlock>

                        <TextBlock Text="3. Connect to the Network" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Foreground="#b9bbbe" TextWrapping="Wrap" Margin="15,0,0,20" FontSize="14">
                            <Run Text="• Go to the "/>
                            <Run FontWeight="Bold" Foreground="White" Text="Home"/>
                            <Run Text=" tab and press "/>
                            <Run FontWeight="Bold" Foreground="White" Text="Activate Syncing"/>
                            <Run Text=". This connects you to the routing network and allows you to start syncing clips!"/>
                            <LineBreak/>
                            <Run Text="• "/>
                            <Run FontStyle="Italic" Text="Optional QoL:"/>
                            <Run Text=" You can also enable "/>
                            <Run FontWeight="Bold" Foreground="White" Text="Sync Automatically"/>
                            <Run Text=" to connect as soon as the app launches, and "/>
                            <Run FontWeight="Bold" Foreground="White" Text="Start with Windows"/>
                            <Run Text=" to have the app launch silently with your PC."/>
                        </TextBlock>

                        <TextBlock Text="4. Build Your Friends List" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Foreground="#b9bbbe" TextWrapping="Wrap" Margin="15,0,0,20" FontSize="14">
                            <Run Text="• Go back to the "/>
                            <Run FontWeight="Bold" Foreground="White" Text="Discord"/>
                            <Run Text=" tab and press "/>
                            <Run FontWeight="Bold" Foreground="White" Text="Select Users"/>
                            <Run Text="."/>
                            <LineBreak/>
                            <Run Text="• Choose the people you wish to send and receive clip commands from (or manually enter their Discord ID)."/>
                            <LineBreak/>
                            <Run Text="• "/>
                            <Run FontWeight="Bold" Foreground="White" Text="Important:"/>
                            <Run Text=" It must be mutual! You and your friend must have each other in your respective lists. The app will not accept commands from users outside your list, and it will not send commands to users outside of your list either."/>
                            <LineBreak/>
                            <LineBreak/>
                            <Run Text="• "/>
                            <Run FontStyle="Italic" Text="Status Icons:"/>
                            <Run Text=" The top right of the "/>
                            <Run FontWeight="Bold" Foreground="White" Text="Home"/>
                            <Run Text=" tab shows the current VC you are in, as well as everyone else in it. A green circle is connected to the app, and a red circle is disconnected. To the left of each user will be either "/>
                            <Run FontWeight="Bold" Foreground="White" Text="+"/>
                            <Run Text=", "/>
                            <Run FontWeight="Bold" Foreground="White" Text="-"/>
                            <Run Text=", "/>
                            <Run FontWeight="Bold" Foreground="White" Text="*"/>
                            <Run Text=", or nothing. "/>
                            <Run FontWeight="Bold" Foreground="White" Text="+"/>
                            <Run Text=" is when only you approve them, "/>
                            <Run FontWeight="Bold" Foreground="White" Text="-"/>
                            <Run Text=" is when only they approve you, "/>
                            <Run FontWeight="Bold" Foreground="White" Text="*"/>
                            <Run Text=" is when you both approve each other, and nothing will show when neither approves the other."/>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <Grid x:Name="SelectUsersOverlay" Visibility="Collapsed" Grid.ColumnSpan="2" Background="#99000000" Panel.ZIndex="100">
            <Border Background="#36393f" Width="400" Height="500" CornerRadius="8" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="SelectUsersTitle" Text="Select Users (Fetching...)" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBox x:Name="SearchUsersInput" Grid.Row="1" Height="30" Background="#202225" Foreground="White" BorderBrush="#202225" Margin="0,0,0,10" VerticalContentAlignment="Center" Padding="5,0" TextChanged="SearchUsersInput_TextChanged"/>

                    <ListBox x:Name="AllUsersListBox" Grid.Row="2" Background="#202225" BorderBrush="#202225" Foreground="White" SelectionMode="Multiple" ScrollViewer.VerticalScrollBarVisibility="Auto" Padding="5">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" Padding="5" Cursor="Hand" ToolTip="{Binding Id}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Cancel" Width="80" Height="30" Background="#4f545c" Foreground="White" BorderThickness="0" Margin="0,0,10,0" Click="CloseSelectUsersBtn_Click"/>
                        <Button Content="Add Selected" Width="100" Height="30" Background="#5865F2" Foreground="White" BorderThickness="0" Click="SubmitSelectedUsersBtn_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>