<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
	<UseWindowsForms>true</UseWindowsForms>
    <ApplicationManifest>app.manifest</ApplicationManifest>
	<IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
	<ApplicationIcon>sosmall.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="clip_renamer\ClipRenamer.exe" />
    <None Remove="images\littlegray.png" />
    <None Remove="images\littlesmall.png" />
    <None Remove="sosmall.ico" />
    <None Remove="sounds\clippedteto.wav" />
    <None Remove="sounds\confusedindividual-clipped!.wav" />
    <None Remove="sounds\confusedindividual-clipped.mp3" />
    <None Remove="sounds\simpleyviridian-clipped.wav" />
    <None Remove="sounds\simpleyviridian-clipped2.wav" />
    <None Remove="sounds\simpleyviridian-clippedteto.wav" />
    <None Remove="sounds\system\confusedindividual-server connect.wav" />
    <None Remove="sounds\system\confusedindividual-server disconnect.wav" />
    <None Remove="sounds\system\simpleyviridian-connected.wav" />
    <None Remove="sounds\system\simpleyviridian-connected2.wav" />
    <None Remove="sounds\system\simpleyviridian-disconnected.wav" />
    <None Remove="sounds\system\simpleyviridian-disconnected2.wav" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="sosmall.ico" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="InputSimulator" Version="1.0.4" />
    <PackageReference Include="NHotkey.Wpf" Version="4.0.0" />
  </ItemGroup>

  <ItemGroup>
		<Using Remove="System.Windows.Forms" />
		<Using Remove="System.Drawing" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="clip_renamer\ClipRenamer.exe" />
    <EmbeddedResource Include="images\littlegray.png" />
    <EmbeddedResource Include="images\littlesmall.png" />
    <EmbeddedResource Include="sounds\confusedindividual-clipped!.wav" />
    <EmbeddedResource Include="sounds\confusedindividual-clipped.mp3" />
    <EmbeddedResource Include="sounds\simpleyviridian-clipped.wav" />
    <EmbeddedResource Include="sounds\simpleyviridian-clipped2.wav" />
    <EmbeddedResource Include="sounds\simpleyviridian-clippedteto.wav" />
    <EmbeddedResource Include="sounds\system\confusedindividual-server connect.wav" />
    <EmbeddedResource Include="sounds\system\confusedindividual-server disconnect.wav" />
    <EmbeddedResource Include="sounds\system\simpleyviridian-connected.wav" />
    <EmbeddedResource Include="sounds\system\simpleyviridian-connected2.wav" />
    <EmbeddedResource Include="sounds\system\simpleyviridian-disconnected.wav" />
    <EmbeddedResource Include="sounds\system\simpleyviridian-disconnected2.wav" />
  </ItemGroup>

</Project>
