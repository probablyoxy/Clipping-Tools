<Window x:Class="ClippingToolsInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clipping Tools Installer" Height="440" Width="400" MinHeight="440" MinWidth="400" Background="#1e1e1e" WindowStartupLocation="CenterScreen">
    <Grid Background="#36393f">
        <StackPanel Margin="30" VerticalAlignment="Center">
            <TextBlock Text="Install Clipping Tools" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
            <TextBlock Text="This will download the latest version from GitHub." Foreground="#b9bbbe" FontSize="14" Margin="0,0,0,30" HorizontalAlignment="Center"/>

            <TextBlock Text="Install Location:" Foreground="White" FontWeight="Bold" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="InstallPathInput" Grid.Column="0" Text="C:\Program Files\Clipping Tools" Height="30" Background="#202225" Foreground="White" BorderBrush="#202225" VerticalContentAlignment="Center" Padding="5,0" Margin="0,0,10,0"/>
                <Button Grid.Column="1" Content="Browse" Height="30" Background="#4f545c" Foreground="White" BorderThickness="0" Click="BrowseBtn_Click"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20" HorizontalAlignment="Center">
                <CheckBox x:Name="StartMenuShortcutCheck" Content="Start Menu Shortcut" Foreground="White" IsChecked="True" Margin="0,0,20,0"/>
                <CheckBox x:Name="DesktopShortcutCheck" Content="Desktop Shortcut" Foreground="White" IsChecked="True"/>
            </StackPanel>

            <Button x:Name="InstallBtn" Content="Install" Height="45" Background="#5865F2" Foreground="White" FontWeight="Bold" FontSize="16" Click="InstallBtn_Click"/>

            <TextBlock x:Name="StatusText" Text="" Foreground="#b9bbbe" Margin="0,20,0,5" HorizontalAlignment="Center"/>
            <ProgressBar x:Name="InstallProgress" Height="10" Width="340" Visibility="Collapsed"/>

            <Button x:Name="ManageAppBtn" Content="Manage Clipping Tools" Height="30" Width="200" Background="#4f545c" Foreground="White" FontWeight="Bold" Margin="0,20,0,0" Visibility="Collapsed" Click="ManageAppBtn_Click"/>
        </StackPanel>

        <Grid x:Name="ManageOverlay" Visibility="Collapsed" Background="#99000000" Panel.ZIndex="100">
            <Border Background="#36393f" Width="300" Height="200" CornerRadius="8" Padding="20">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Manage Clipping Tools" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <Button x:Name="ResetSettingsBtn" Content="Reset Settings File" Height="35" Background="#4f545c" Foreground="White" BorderThickness="0" Margin="0,0,0,10" Click="ResetSettingsBtn_Click"/>
                    <Button x:Name="DeleteDataBtn" Content="Delete Clipping Tools Data" Height="35" Background="#f04747" Foreground="White" BorderThickness="0" Margin="0,0,0,15" Click="DeleteDataBtn_Click"/>
                    <Button Content="Cancel" Width="100" Height="30" Background="#2f3136" Foreground="White" BorderThickness="0" HorizontalAlignment="Center" Click="CloseManageOverlayBtn_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="ConfirmManageOverlay" Visibility="Collapsed" Background="#99000000" Panel.ZIndex="110">
            <Border Background="#36393f" Width="300" MinHeight="150" CornerRadius="8" Padding="20" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="ConfirmManageTitle" Text="Confirm Action" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="ConfirmManageText" Text="Are you sure?" Foreground="#b9bbbe" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="No" Width="80" Height="30" Background="#4f545c" Foreground="White" BorderThickness="0" Margin="0,0,10,0" Click="ConfirmManageCancelBtn_Click"/>
                        <Button x:Name="ConfirmManageOkBtn" Content="Yes" Width="80" Height="30" Background="#f04747" Foreground="White" BorderThickness="0" Click="ConfirmManageOkBtn_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>